# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rift
DB_USER=rift
DB_PASSWORD=123

# App
ENVIRONMENT=local   # local | staging | production

# Admin seed (created on startup if not exists)
ADMIN_EMAIL=admin@rift.dev
ADMIN_PASSWORD=admin123

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
JWT_EXP=30   # minutes (admin); public user JWT is always 30 days

# Discord OAuth2 (public user login)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback
FRONTEND_URL=http://localhost:3000
APP_ENV=local   # local | staging | production (controls cookie_secure)
